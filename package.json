{
  "name": "tollab",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Tollab - Academic management web application for Technion students",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/itabajah/Tollab.git"
  },
  "keywords": [
    "technion",
    "university",
    "academic",
    "course-management",
    "student",
    "preact",
    "typescript"
  ],
  "author": "Ibrahim Tabajah",
  "license": "MIT",
  "dependencies": {
    "firebase": "^12.11.0",
    "immer": "^11.1.4",
    "preact": "^10.25.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@preact/preset-vite": "^2.9.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/preact": "^3.2.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.48.0",
    "prettier": "^3.4.0",
    "react": "npm:@preact/compat@^18.3.2",
    "react-dom": "npm:@preact/compat@^18.3.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
